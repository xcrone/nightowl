{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/destructive-db-block.sh",
            "statusMessage": "Guarding against destructive DB commands"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/uuid-public-ids-block.sh",
            "statusMessage": "Checking UUID-only public identifiers"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/action-test-reminder.sh",
            "statusMessage": "Checking Action test coverage"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/routes-export-reminder.sh",
            "statusMessage": "Checking routes export"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/domain-readme-reminder.sh",
            "statusMessage": "Checking domain README sync"
          }
        ]
      }
    ]
  }
}
