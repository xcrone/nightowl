# Builds the web/ Vue3 SPA as a static bundle and serves it via `vite preview`.
# POC-scale, matching docker-compose.yml's other services — swap for an
# nginx-served static build when this needs to handle real traffic.
FROM node:22-alpine

WORKDIR /app

# VITE_* vars are inlined into the JS bundle at build time, not read at
# container runtime — must be passed as a build arg, not `environment:`.
ARG VITE_API_URL
ENV VITE_API_URL=$VITE_API_URL

COPY package.json pnpm-lock.yaml ./
# Pinned to match the version this lockfile was generated with — newer pnpm
# majors (11+) enforce a "minimum release age" supply-chain policy by
# default that rejects just-published packages already in the lockfile.
RUN corepack enable && corepack prepare pnpm@10.21.0 --activate && pnpm install --frozen-lockfile

COPY . .
RUN pnpm build

EXPOSE 4173

CMD ["pnpm", "preview", "--host", "--port", "4173"]
