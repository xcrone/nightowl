# Shared dev-only values consumed by docker-compose.yml (variable
# substitution — Compose loads .env from this directory automatically).
#
# Copy to .env: `cp .env.example .env`
#
# Fixed, non-secret dev/POC values — replace them in .env for anything
# shared or long-lived. agent/, api/, and web/ each still keep their own
# .env (Laravel and Vite each expect one in their own project root), so
# this file only exists to stop docker-compose.yml repeating the same
# credentials across its postgres/agent/api services.

NIGHTOWL_DB_DATABASE=nightowl
NIGHTOWL_DB_USERNAME=nightowl
NIGHTOWL_DB_PASSWORD=nightowl

# Shared Laravel APP_KEY baked into both the agent and api containers.
NIGHTOWL_APP_KEY=base64:lOO9am44Du77Je2OPn8qquhmhc05wmAbsOoCvT6Bzd8=

# api's CORS/Sanctum config and web's build-time API base URL — keep in
# sync with the host port mappings in docker-compose.yml.
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:8000
